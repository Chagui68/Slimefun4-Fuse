        <module>sources/community-addons/DankTech2</module>
        <module>sources/community-addons/DyeBench</module>
        <module>sources/community-addons/Element-Manipulation</module>
        <module>sources/community-addons/ExtraTools</module>
        <module>sources/community-addons/FlowerPower</module>
        <module>sources/community-addons/FN-FAL-s-Amplifications</module>
