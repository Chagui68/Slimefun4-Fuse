        <module>sources/repos-to-port/InfinityExpansion</module>
        <module>sources/repos-to-port/luckyblocks-sf</module>
        <module>sources/repos-to-port/PrivateStorage</module>
        <module>sources/repos-to-port/SFCalc</module>
        <module>sources/repos-to-port/SFMobDrops</module>
        <module>sources/repos-to-port/SimpleUtils</module>
        <module>sources/repos-to-port/SlimeChem</module>
